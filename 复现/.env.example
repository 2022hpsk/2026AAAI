# 复制本文件为 .env 后填入凭据（.env 已被 .gitignore，不会入库）。
# 各 runner 启动时会自动加载 .env（见 run_baseline.py / run_mem0.py）。
# QA-agent + judge 需要一个可调用的 LLM；下面选一种填即可，其余留空。

# ── 方案 0（主用）：DeepSeek（--llm-provider deepseek，默认模型 deepseek-v4-flash）─
# OpenAI 兼容接口，Bearer 鉴权。base_url 用 https://api.deepseek.com。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 方案 A：Anthropic（--llm-provider anthropic）────────────────────────────
# 注意：必须是真正的 API key（sk-ant-...），不能用 Claude Code 的 OAuth。
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── 方案 B：本地 vLLM / 任意 OpenAI 兼容服务（--llm-provider local）─────────
# 例：vllm serve Qwen/Qwen2.5-7B-Instruct  ->  base_url=http://localhost:8000/v1
# 本地服务 key 填任意非空字符串即可（如 EMPTY）。
OPENAI_API_KEY=
OPENAI_BASE_URL=
